{
  "hooks": [
    {
      "event": "PreToolUse",
      "matcher": "run_command",
      "command": "python scripts/harness/security_guard.py",
      "timeout": 5
    },
    {
      "event": "Stop",
      "matcher": "",
      "command": "bash scripts/harness/quality_gate.sh",
      "timeout": 30
    }
  ],
  "shellAllowed": [
    "git",
    "npm",
    "npx",
    "python",
    "python3",
    "pip",
    "cargo",
    "go",
    "rustc",
    "make",
    "node",
    "tsc",
    "eslint",
    "prettier",
    "ruff",
    "black",
    "mypy",
    "pytest",
    "uv",
    "copier"
  ]
}
